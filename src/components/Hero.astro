---
import HeroScene from './HeroScene';
---

<section class="hero" id="hero">
  <HeroScene client:only="preact" />
  <h1 class="hero__title anim-fade-up">Premium 3D Assets<br/>for Your Next Project</h1>
  <div class="hero__bottom anim-fade-up">
    <p class="hero__subtitle">Three meticulously crafted Three.js scenes — one buyer per asset, no double selling. Browse, order, and own the source code.</p>
    <a href="#catalog" class="hero__cta">View Catalog ↓</a>
  </div>
</section>

<style>
  .hero { position: relative; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: space-between; overflow: hidden; color: var(--color-white); padding: 60px 20px; }
  .hero__title { position: relative; z-index: 1; text-align: center; font-size: clamp(28px, 5vw, 48px); text-shadow: 0 0 40px rgba(0, 0, 0, 0.8), 0 2px 20px rgba(0, 0, 0, 0.6); }
  .hero__bottom { position: relative; z-index: 1; text-align: center; max-width: 600px; }
  .hero__subtitle { font-size: 16px; color: var(--color-text-grey); margin-bottom: var(--spacing-xl); text-shadow: 0 1px 10px rgba(0, 0, 0, 0.8); }
  .hero__cta { display: inline-block; padding: 14px 32px; background-color: var(--color-accent); color: var(--color-black); font-weight: var(--font-weight-medium); border-radius: var(--radius-pill); transition: opacity 0.2s, transform 0.2s; }
  .hero__cta:hover { opacity: 0.9; transform: translateY(-1px); }
  @media (max-width: 768px) { .hero { padding: 40px 16px; } .hero__subtitle { font-size: 14px; } }
</style>
