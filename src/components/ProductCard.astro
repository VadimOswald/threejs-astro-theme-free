---
interface Props { id: string; name: string; description: string; price: number; videoSrc: string; posterSrc: string; }
const { id, name, description, price, videoSrc, posterSrc } = Astro.props;
---

<div class="product-card" data-product={id}>
  <div class="product-card__media">
    <video autoplay loop muted playsinline preload="metadata" poster={posterSrc} aria-label={`${name} 3D scene preview`}>
      <source src={videoSrc} type="video/mp4" />
    </video>
  </div>
  <div class="product-card__info">
    <h3 class="product-card__name">{name}</h3>
    <p class="product-card__desc">{description}</p>
    <div class="product-card__footer">
      <span class="product-card__price">${price}</span>
      <button class="product-card__btn" aria-label={`Add ${name} to order`} data-id={id} data-name={name} data-price={price}>Add to Order</button>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.product-card__btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      window.dispatchEvent(new CustomEvent('add-to-cart', { detail: { id: el.dataset.id, name: el.dataset.name, price: Number(el.dataset.price) } }));
    });
  });
</script>

<style>
  .product-card { background: var(--color-white); border-radius: var(--radius-card); overflow: hidden; box-shadow: var(--shadow-card); transition: box-shadow 0.3s, transform 0.3s; display: flex; flex-direction: column; }
  .product-card:hover { box-shadow: var(--shadow-hover); transform: translateY(-4px); }
  .product-card__media { aspect-ratio: 4 / 3; background: var(--color-off-white); overflow: hidden; }
  .product-card__media video { width: 100%; height: 100%; object-fit: cover; }
  .product-card__info { padding: var(--spacing-lg); display: flex; flex-direction: column; flex: 1; }
  .product-card__name { margin-bottom: var(--spacing-sm); }
  .product-card__desc { font-size: var(--text-caption-size); color: var(--color-text-grey); margin-bottom: var(--spacing-lg); flex: 1; }
  .product-card__footer { display: flex; align-items: center; justify-content: space-between; }
  .product-card__price { font-size: 20px; font-weight: var(--font-weight-bold); color: var(--color-black); }
  .product-card__btn { padding: 10px 20px; background-color: var(--color-black); color: var(--color-white); font-weight: var(--font-weight-medium); font-size: var(--text-caption-size); border-radius: var(--radius-pill); transition: opacity 0.2s, background-color 0.2s; }
  .product-card__btn:hover { background-color: var(--color-dark-grey); }
</style>
