---
import ProductCard from './ProductCard.astro';
const products = [
  { id: 'abstract-flow', name: 'Abstract Flow', description: 'The golden icosahedron - twenty facets of exquisite work. The metal is polished almost to the mirror, and a thin gold mesh has drilled at the edges, so the figure seems carved like stone. The scene can be rotated with your hands. Suitable for expensive designs - decor, art, an element of luxury style.', price: 19, videoSrc: '/assets/videos/abstract-flow.webm', posterSrc: '/assets/posters/abstract-flow.jpg' },
  { id: 'geometric-nexus', name: 'Geometric Nexus', description: 'The sphere star is a ball of thorns made from hundreds of thorns. The procedural noise broke symmetry, and each protrusion came out in its own way. The color moves from deep blue into a thick violet, exploding with pink and blue at the edges. Inside the core burns, and light penetrates through the structure.', price: 24, videoSrc: '/assets/videos/geometric-nexus.webm', posterSrc: '/assets/posters/geometric-nexus.jpg' },
  { id: 'ethereal-glass', name: 'Ethereal Glass', description: 'A geometric cube with pyramidal projections on each face - the structure is star-shaped and at the same time collected, architectural. The whole figure is covered with a neon net. Thick lines give a bright contour, thin - a soft twinkle that goes from deep blue to rich pink.', price: 29, videoSrc: '/assets/videos/ethereal-glass.webm', posterSrc: '/assets/posters/ethereal-glass.jpg' },
];
---

<section class="catalog section" id="catalog">
  <div class="container">
    <h2 class="catalog__title anim-reveal">Browse the Catalog</h2>
    <div class="catalog__grid">
      {products.map(p => <ProductCard {...p} />)}
    </div>
  </div>
</section>

<style>
  .catalog { background-color: var(--color-white); }
  .catalog__title { text-align: center; margin-bottom: var(--spacing-3xl); }
  .catalog__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--grid-gutter); }
  @media (max-width: 1024px) { .catalog__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .catalog__grid { grid-template-columns: 1fr; } }
</style>
